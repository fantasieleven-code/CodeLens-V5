# CodeLens V5 Server — environment variables
# Copy to .env and fill in the required fields before `npm run dev`.
# Source of truth: packages/server/src/config/env.ts (zod schema).

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── Database (required) ──────────────────────────────────
DATABASE_URL=postgresql://codelens:password@localhost:5432/codelens_v5_dev

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (JWT_SECRET required, min 16 chars) ──────────────
JWT_SECRET=change-me-in-production-min-16-chars
JWT_CANDIDATE_EXPIRY=90m
JWT_ADMIN_EXPIRY=8h

# ── RTC callback (min 16 chars if set) ───────────────────
# Dedicated secret for Volcano RTC callbacks — NEVER reuse JWT_SECRET.
RTC_CALLBACK_SECRET=

# ── Sandbox provider ('e2b' | 'docker') ──────────────────
SANDBOX_PROVIDER=e2b

# ── E2B (optional) ───────────────────────────────────────
E2B_API_KEY=
E2B_SANDBOX_TIMEOUT_MS=4800000

# ── AI Tier 1: Doubao / ARK ──────────────────────────────
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_PRO=
ARK_MODEL_LITE=

# ── AI Tier 2: DeepSeek ──────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── AI: DashScope (Qwen) — MB1 agent ─────────────────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-coder-plus

# ── AI Tier 3: Claude ────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1/
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── AI: GLM (Zhipu) — V5.0 scoring / structured output ───
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_DEFAULT_MODEL=glm-4-plus

# ── AI concurrency ───────────────────────────────────────
AI_CONCURRENCY_LIMIT=8

# ── Langfuse (optional) ──────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Volcano RTC (CP4 voice, optional) ────────────────────
VOLC_RTC_APP_ID=
VOLC_RTC_APP_KEY=
VOLC_AK=
VOLC_SK=
VOLC_AI_USER_ID=AI_Interviewer01
VOLC_SUBTITLE_CALLBACK_URL=
VOLC_SUBTITLE_SIGNATURE=
VOLC_TTS_SPEAKER=ICL_zh_female_yuxin_v1_tob
VOLC_VAD_SILENCE_TIME=1300
VOLC_INTERRUPT_MODE=0
VOLC_INTERRUPT_SPEECH_DURATION=800
VOLC_LLM_HISTORY_LENGTH=500
VOLC_LLM_TEMPERATURE=1
VOLC_LLM_TOP_P=0.6
VOLC_LLM_MAX_TOKENS=2363
CP4_LLM_MODE=ark
CUSTOM_LLM_URL=

# ── Volcano RTC — ASR/VAD enhancements ───────────────────
VOLC_ASR_EXPIRE_TIME=5000
VOLC_VAD_FORCE_BEGIN_THRESHOLD=100
VOLC_VAD_FORCE_END=1200

# ── Volcano RTC — far-field / TTS / keywords ─────────────
VOLC_ENABLE_FARFIELD=false
VOLC_TTS_PREFILL=false
VOLC_ENABLE_EMOTION_TTS=false
VOLC_INTERRUPT_KEYWORDS=

# ── Volcano RTC — usage callback ─────────────────────────
VOLC_TASK_USAGE_CALLBACK_URL=
VOLC_TASK_USAGE_SIGNATURE=

# ── Volcano RTC — snapshot / parallel tool calls ─────────
VOLC_ENABLE_SNAPSHOT=false
VOLC_ENABLE_PARALLEL_TOOL_CALLS=false

# ── Sentry (optional) ────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Scoring calibration ──────────────────────────────────
SCORING_CALIBRATION=false
SCORING_CALIBRATION_CALLS=2

# ── Admin (ADMIN_PASSWORD required in production) ────────
ADMIN_EMAIL=admin@codelens.dev
ADMIN_PASSWORD=
