// CodeLens V5 schema — clean V5-only.
// Exam data: ExamInstance.businessScenario + ExamModule.moduleSpecific.
// Session.metadata stores V5Submissions; Session.scoringResult stores final scoring.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ───

model Organization {
  id              String      @id @default(uuid())
  name            String
  plan            String      @default("trial") // trial, pro, enterprise
  interviewCount  Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  members       OrgMember[]
  sessions      Session[]
  candidates    Candidate[]
  examInstances ExamInstance[]
  webhooks      WebhookConfig[]
}

model OrgMember {
  id           String    @id @default(uuid())
  orgId        String
  email        String
  name         String
  passwordHash String
  role         String    @default("MEMBER") // OWNER, MEMBER
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
}

// ─── Core ───

model Session {
  id            String    @id @default(uuid())
  candidateId   String
  orgId         String?
  schemaVersion Int       @default(5)
  status        String    @default("CREATED") // CREATED, SANDBOX_READY, IN_PROGRESS, PAUSED, COMPLETED, EXPIRED, ERROR
  sandboxId     String?
  startedAt     DateTime?
  completedAt   DateTime?
  expiresAt     DateTime
  metadata      Json      @default("{}") // V5Submissions
  scoringResult Json?     // { signals, dimensions, composite, grade, dangerFlag }
  // Task B-A12: candidate pre-exam profile (7 fields, CandidateProfile in shared).
  candidateProfile Json?
  // Task B-A12: timestamp at which the candidate accepted the data-use consent.
  consentAcceptedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate    Candidate     @relation(fields: [candidateId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  eventsLog    EventLog[]

  @@index([candidateId])
  @@index([status])
  @@index([orgId])
}

model Candidate {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  orgId          String?
  token          String?
  tokenExpiresAt DateTime?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id])
  sessions     Session[]

  @@index([orgId])
}

// ─── Events ───

model EventLog {
  id        String   @id @default(uuid())
  sessionId String
  category  String   // FILE, TERMINAL, AI, SESSION, SIGNAL, SYSTEM
  type      String
  payload   Json     @default("{}")
  timestamp DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([category])
  @@index([timestamp])
  @@index([sessionId, timestamp])
  @@index([sessionId, category, timestamp])
}

// ─── Leads ───

model Lead {
  id        String   @id @default(uuid())
  name      String
  company   String
  email     String
  phone     String   @default("")
  source    String   @default("landing_page")
  status    String   @default("new") // new, contacted, converted
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ─── Prompt Version Management ───

model PromptVersion {
  id        String   @id @default(uuid())
  name      String
  version   Int      @default(1)
  content   String
  isActive  Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, version])
  @@index([name, isActive])
}

// ─── ATS Webhook ───

model WebhookConfig {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  secret    String
  events    String[] @default(["interview.completed"])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ─── V5 Exam ───

model ExamInstance {
  id               String  @id @default(uuid())
  seed             Int
  businessScenario Json
  techStack        String
  domain           String
  challengePattern String
  archStyle        String?
  level            String
  orgId            String?

  usedCount           Int       @default(0)
  avgCompletionMins   Float?
  avgCompositeScore   Float?
  discriminationScore Float?
  lastUsedAt          DateTime?
  qualityReport       Json?

  organization Organization? @relation(fields: [orgId], references: [id])
  modules      ExamModule[]

  @@index([orgId])
}

model ExamModule {
  id             String   @id @default(uuid())
  examInstanceId String
  moduleType     String   // 'P0' | 'MA' | 'MB' | 'MD' | 'SE' | 'MC'
  scenarioRef    String?
  moduleSpecific Json
  version        Int      @default(1)
  createdAt      DateTime @default(now())

  examInstance ExamInstance @relation(fields: [examInstanceId], references: [id], onDelete: Cascade)

  @@unique([examInstanceId, moduleType])
  @@index([examInstanceId])
}
