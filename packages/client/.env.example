# CodeLens V5 Client — environment variables
#
# Copy to `.env` (all envs) or `.env.development.local` (dev-only, gitignored
# by the root .gitignore) and fill in as needed. All VITE_* vars are baked
# into the bundle at build time; never store secrets here.
#
# Load order (Vite): .env → .env.local → .env.[mode] → .env.[mode].local.
# The `.local` variants win, so use them to override without touching the
# example committed to the repo.

# ── API base URL ─────────────────────────────────────────
# Production: absolute URL to the server (e.g. https://api.codelens.dev).
# Dev: point at a locally-running server (default `http://localhost:4000`)
# or leave empty to force the Admin client into mock mode.
VITE_API_URL=

# ── Admin API mock switch ────────────────────────────────
# Task 12 Layer 2 added a real cutover — each `/admin/*` call now targets
# `/api/admin/*` with a Bearer token sourced from useAuthStore.
#
#   'true'  → force mock (ignores VITE_API_URL; useful for UI-only work)
#   'false' → force real (requires VITE_API_URL + a running server)
#   unset   → auto (mock iff !VITE_API_URL)
VITE_ADMIN_API_MOCK=
