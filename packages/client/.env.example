# CodeLens V5 Client — environment variables
# Copy to .env and fill in as needed. All VITE_* vars are baked into the
# bundle at build time; never store secrets here.

# ── API base URL ─────────────────────────────────────────
# Production: absolute URL to the server (e.g. https://api.codelens.dev).
# Dev: leave empty to route through the Vite proxy to :4000.
VITE_API_URL=

# ── Admin API mock switch ────────────────────────────────
#   'true'  → force mock (ignores VITE_API_URL)
#   'false' → force real (requires VITE_API_URL)
#   unset   → auto (mock iff !VITE_API_URL)
VITE_ADMIN_API_MOCK=
