  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace=@codelens-v5/shared",
    "dev": "vite",
    "prebuild": "npm run build --workspace=@codelens-v5/shared",
    "build": "tsc && vite build",
