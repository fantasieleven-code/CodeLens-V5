# ── Database ──
# Connection pool: append ?connection_limit=10 for production (default is unlimited)
# Recommended: 10 for single instance, 5 per instance if running multiple replicas
DATABASE_URL=postgresql://codelens:codelens@localhost:5432/codelens
DIRECT_URL=postgresql://codelens:codelens@localhost:5432/codelens

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_CANDIDATE_EXPIRY=90m
JWT_ADMIN_EXPIRY=8h

# ── RTC Callback (dedicated secret for Volcano RTC /chat-stream auth) ──
RTC_CALLBACK_SECRET=

# ── Server ──
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── E2B Sandbox ──
E2B_API_KEY=
E2B_SANDBOX_TIMEOUT_MS=4800000

# ── AI Providers (3-tier degradation) ──
# Tier 1: Doubao (ARK)
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_PRO=
ARK_MODEL_LITE=

# Tier 2: DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tier 3: Claude (fallback)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── AI Concurrency ──
AI_CONCURRENCY_LIMIT=8

# ── Langfuse (optional) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Volcano RTC Voice (required when CP4 voice features are enabled) ──
# VOLC_RTC_APP_ID=
# VOLC_RTC_APP_KEY=
# VOLC_AK=
# VOLC_SK=
# VOLC_SUBTITLE_CALLBACK_URL=
# VOLC_SUBTITLE_SIGNATURE=  # HMAC key for webhook verification — generate with: openssl rand -hex 32
# CP4_LLM_MODE=ark           # ark | custom

# ── Volcano RTC Voice — Advanced Config (all optional, safe defaults) ──
# VOLC_ASR_EXPIRE_TIME=5000           # ASR强制判停兜底(ms)，噪声环境防卡死
# VOLC_VAD_FORCE_BEGIN_THRESHOLD=100  # VAD极速打断阈值(ms)
# VOLC_VAD_FORCE_END=1200             # VAD辅助强制判停(ms)
# VOLC_ENABLE_FARFIELD=false          # 远场人声抑制（抑制3-5m外背景人声）
# VOLC_TTS_PREFILL=false              # 关闭TTS预合成，降低ASR中间结果修正时的字符消耗
# VOLC_ENABLE_EMOTION_TTS=false       # 情绪TTS：AI语气随对话情感调整
# VOLC_INTERRUPT_KEYWORDS=            # 逗号分隔的打断关键词，如: 等一下,我想想,稍等
# VOLC_TASK_USAGE_CALLBACK_URL=       # 接收taskUsage用量回调的Webhook URL
# VOLC_TASK_USAGE_SIGNATURE=          # 用量回调HMAC签名密钥
# VOLC_ENABLE_SNAPSHOT=false          # 图片理解：SnapshotConfig.AutoSelect智能选帧
# VOLC_ENABLE_PARALLEL_TOOL_CALLS=false  # 并行函数调用

# ── Admin ──
ADMIN_EMAIL=admin@codelens.dev
ADMIN_PASSWORD=change-me
